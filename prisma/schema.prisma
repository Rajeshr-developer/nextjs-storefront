generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int       @id @default(autoincrement())
  name       String
  email      String    @unique
  age        Int?
  role       String?
  active     Boolean?
  created_at DateTime? @default(now())
  orders     Order[]

  @@map("users")
}

model Product {
  id         Int       @id @default(autoincrement())
  name       String
  price      Decimal
  category   String?
  stock      Int?
  created_at DateTime? @default(now())
  orders     Order[]

  @@map("products")
}

model Order {
  id          Int       @id @default(autoincrement())
  user_id     Int?
  product_id  Int?
  quantity    Int?
  total_price Decimal?
  status      String?
  created_at  DateTime? @default(now())
  user        User?     @relation(fields: [user_id], references: [id])
  product     Product?  @relation(fields: [product_id], references: [id])

  @@map("orders")
}